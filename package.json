  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.58.2",
    "@quasar/vite-plugin": "^1.10.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "~10.3.0",
