    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.59.1",
    "@quasar/vite-plugin": "^1.11.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.6",
