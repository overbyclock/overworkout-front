# ============================================
# OverWorkout Admin - Environment Variables
# ============================================
# Copia este archivo a .env.local y rellena los valores
# NUNCA subas .env.local a GitHub (ya está en .gitignore)

# ============================================
# API CONFIGURATION
# ============================================
# URL del backend API
VITE_API_BASE_URL=http://localhost:8000

# Timeout para peticiones (ms)
VITE_API_TIMEOUT=30000

# ============================================
# APP CONFIGURATION
# ============================================
# Nombre de la aplicación
VITE_APP_NAME=OverWorkout Admin

# Versión (opcional, se lee de package.json por defecto)
# VITE_APP_VERSION=1.0.0

# Entorno (development/production)
VITE_APP_ENV=development

# ============================================
# FEATURE FLAGS (Opcional)
# ============================================
# Habilitar modo debug
VITE_DEBUG_MODE=false

# Habilitar analytics
VITE_ENABLE_ANALYTICS=false

# ============================================
# NOTAS DE SEGURIDAD
# ============================================
# 1. NUNCA subas este archivo con valores reales a GitHub
# 2. Si necesitas cambiar la URL del API en producción:
#    - Para GitHub Pages: usa variables de entorno del hosting
#    - Para Vercel/Netlify: configura en el dashboard
#    - Para servidor propio: usa el .env en el servidor
# 
# 3. El token JWT se maneja automáticamente por la app
#    No necesitas configurarlo aquí
